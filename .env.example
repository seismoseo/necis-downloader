# NECIS credentials — copy this file to .env and fill in your values.
# .env is git-ignored; never commit real credentials.

NECIS_USER=your_necis_username
NECIS_PASS=your_necis_password

# Optional overrides (defaults shown)
# NECIS_HEADLESS=1          # set to 0 to see the browser window
# NECIS_DOWNLOAD_DIR=data/necis
